# ═══════════════════════════════════════════════════════════════
# Orbital Industries — Production Environment
# ═══════════════════════════════════════════════════════════════

# ── Core App ───────────────────────────────────────────────────
SECRET_KEY=CHANGE-ME-TO-64-RANDOM-CHARS-USE-OPENSSL
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE-ME-TO-STRONG-PASSWORD
ADMIN_BYPASS_LOCAL=false

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=sqlite:////app/instance/orbital.db

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── AI / LLM ───────────────────────────────────────────────────
AI_PROVIDER=ollama
AI_MODEL=llama3.1:8b
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_TIMEOUT=15
OLLAMA_API_KEY=

# ── Browser / Crawler ──────────────────────────────────────────
BROWSER_HEADLESS=true
BROWSER_POOL_SIZE=2
CHROME_BIN=/usr/bin/chromium
CHROMEDRIVER_PATH=/usr/bin/chromedriver
SELENIUM_POOL_SIZE=2
SELENIUM_RETRY_ATTEMPTS=3
SELENIUM_PAGE_LOAD_TIMEOUT=25
DISABLE_LLM_FORMS=true

# ── Pipeline ───────────────────────────────────────────────────
PIPELINE_MAX_CONCURRENT=1
PIPELINE_BATCH_SIZE=5
DISCOVER_INTERVAL_MINUTES=10
PROCESS_INTERVAL_MINUTES=1
TARGET_TIMEOUT=90

# ── Crawl4AI ───────────────────────────────────────────────────
CRAWL4AI_URL=http://crawl4ai:11235
CRAWL4AI_API_KEY=orbital-local-key
MAX_CONCURRENT_CRAWLS=3
CRAWL_TIMEOUT=45

# ── Integrations ───────────────────────────────────────────────
TWOCAPTCHA_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFICATION_EMAIL=

# ── Temporal (DISABLED in prod unless you run a Temporal server) ─
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=default
